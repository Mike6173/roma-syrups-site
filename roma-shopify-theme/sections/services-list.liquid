<!-- Page Hero -->
<section class="page-hero"
  style="background-image: url({{ 'services-hero.jpg' | asset_url }});">
  <div class="page-hero-overlay"></div>
  <div class="container page-hero-content">
    <h1>Our Services</h1>
    <p>Expert installation, repair, and maintenance for commercial beverage systems.</p>
  </div>
</section>

<!-- Services Grid -->
<section class="section-services">
  <div class="container">
    <div class="services-grid">

      <!-- Installation -->
      <div class="service-card">
        <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08
                   a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51
                   a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08
                   a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18
                   a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39
                   a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09
                   a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25
                   a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z"/>
          <circle cx="12" cy="12" r="3"/>
        </svg>
        <h2>Installation</h2>
        <p>Complete installation of soda systems, draft beer systems, wine on tap, water filtration, coffee on tap and refrigeration equipment. Our expert technicians handle everything from design to final testing.</p>
        <a href="/pages/contact" class="link-gold">Request Service &rarr;</a>
      </div>

      <!-- Repair -->
      <div class="service-card">
        <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77
                   a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91
                   a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>
        </svg>
        <h2>Repair</h2>
        <p>Fast, reliable repair service for all commercial beverage equipment. Our skilled team diagnoses and fixes problems quickly to minimize your downtime.</p>
        <a href="/pages/contact" class="link-gold">Request Service &rarr;</a>
      </div>

      <!-- Line Cleaning -->
      <div class="service-card">
        <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M7 16.3c2.2 0 4-1.83 4-4.05 0-1.16-.57-2.26-1.71-3.19S7.29 6.75 7 5.3
                   c-.29 1.45-1.14 2.84-2.29 3.76S3 11.1 3 12.25c0 2.22 1.8 4.05 4 4.05z"/>
          <path d="M12.56 6.6A10.97 10.97 0 0 0 14 3.02c.5 2.5 2 4.9 4 6.5s3 3.5 3 5.5
                   a6.98 6.98 0 0 1-11.91 4.97"/>
        </svg>
        <h2>Line Cleaning</h2>
        <p>Regular line cleaning is essential for quality beverages and food safety compliance. We provide professional beer line cleaning, soda line cleaning, and glycol system maintenance.</p>
        <a href="/pages/contact" class="link-gold">Request Service &rarr;</a>
      </div>

      <!-- Preventive Maintenance -->
      <div class="service-card">
        <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10"/>
          <polyline points="12 6 12 12 16 14"/>
        </svg>
        <h2>Preventive Maintenance</h2>
        <p>Keep your systems running at peak performance with our preventive maintenance programs. Regular inspections, cleaning, and tune-ups extend equipment life and prevent costly breakdowns.</p>
        <a href="/pages/contact" class="link-gold">Request Service &rarr;</a>
      </div>

    </div><!-- /.services-grid -->
  </div><!-- /.container -->
</section>

<!-- 24-Hour CTA -->
<section class="section-dark" style="padding:4rem 0;text-align:center;">
  <div class="container">
    <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none"
         stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
         style="margin:0 auto;color:var(--gold);">
      <circle cx="12" cy="12" r="10"/>
      <polyline points="12 6 12 12 16 14"/>
    </svg>
    <h2 style="font-family:'Oswald',sans-serif;font-size:clamp(1.5rem,3.5vw,2.25rem);font-weight:700;
               text-transform:uppercase;letter-spacing:0.05em;margin-top:1rem;">
      24-Hour Service Response
    </h2>
    <p style="max-width:40rem;margin:1rem auto 0;font-family:'Source Sans 3',sans-serif;opacity:0.8;">
      We understand that equipment downtime costs you money. That's why our service center is committed
      to responding to your service requests within 24 hours. Call us anytime.
    </p>
    <a href="tel:718-259-1842" class="btn btn-gold" style="margin-top:1.5rem;display:inline-flex;">
      Call 718-259-1842
    </a>
  </div>
</section>


<!-- Page Hero -->
<section class="page-hero"
  style="background-image: url({{ 'services-hero.jpg' | asset_url }});">
  <div class="page-hero-overlay"></div>
  <div class="container page-hero-content">
    <h1>Our Products</h1>
    <p>Commercial beverage systems and equipment for every need.</p>
  </div>
</section>

<!-- Products Categories -->
<section class="section-catalog" style="padding-top:5rem;padding-bottom:5rem;">
  <div class="container">
    <div class="catalog-categories-grid">

      <!-- Soda Systems -->
      <div class="catalog-cat-card">
        <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M7 16.3c2.2 0 4-1.83 4-4.05 0-1.16-.57-2.26-1.71-3.19S7.29 6.75 7 5.3
                   c-.29 1.45-1.14 2.84-2.29 3.76S3 11.1 3 12.25c0 2.22 1.8 4.05 4 4.05z"/>
          <path d="M12.56 6.6A10.97 10.97 0 0 0 14 3.02c.5 2.5 2 4.9 4 6.5s3 3.5 3 5.5
                   a6.98 6.98 0 0 1-11.91 4.97"/>
        </svg>
        <h2>Soda Systems</h2>
        <p>Soda Fountains (New &amp; Used), Bar Guns, Jet Sprays, Carbonators, CO2 &amp; G-Mix Tanks</p>
        <a href="/pages/contact" class="link-gold" style="display:inline-block;margin-top:1rem;font-family:'Oswald',sans-serif;font-size:0.875rem;font-weight:600;text-transform:uppercase;letter-spacing:0.05em;color:var(--gold);">Request Quote &rarr;</a>
      </div>

      <!-- Draft Beer -->
      <div class="catalog-cat-card">
        <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M17 11h1a3 3 0 0 1 0 6h-1"/>
          <path d="M9 12v6"/><path d="M13 12v6"/>
          <path d="M14 7.5c-1 0-1.44.5-3 .5s-2-.5-3-.5-1.44.5-3 .5"/>
          <path d="M14 4.5c-1 0-1.44.5-3 .5s-2-.5-3-.5-1.44.5-3 .5"/>
          <path d="M3 7.5h14v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-9z"/>
        </svg>
        <h2>Draft Beer Systems</h2>
        <p>Kegerators, Multi-Tier Beer Systems, Beer Towers, Glycol Systems, Beer Line Cleaning Equipment</p>
        <a href="/pages/contact" class="link-gold" style="display:inline-block;margin-top:1rem;font-family:'Oswald',sans-serif;font-size:0.875rem;font-weight:600;text-transform:uppercase;letter-spacing:0.05em;color:var(--gold);">Request Quote &rarr;</a>
      </div>

      <!-- Wine on Tap -->
      <div class="catalog-cat-card">
        <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M8 22h8"/><path d="M7 10h10"/><path d="M12 15v7"/>
          <path d="M12 15a5 5 0 0 0 5-5c0-2-.5-4-2-8H9C7.5 6 7 8 7 10a5 5 0 0 0 5 5z"/>
        </svg>
        <h2>Wine on Tap</h2>
        <p>Wine Dispensing Systems, Wine Preservation, Tap Handles &amp; Accessories</p>
        <a href="/pages/contact" class="link-gold" style="display:inline-block;margin-top:1rem;font-family:'Oswald',sans-serif;font-size:0.875rem;font-weight:600;text-transform:uppercase;letter-spacing:0.05em;color:var(--gold);">Request Quote &rarr;</a>
      </div>

      <!-- Refrigeration -->
      <div class="catalog-cat-card">
        <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="2" y1="12" x2="22" y2="12"/>
          <line x1="12" y1="2" x2="12" y2="22"/>
          <path d="m20 16-4-4 4-4"/>
          <path d="m4 8 4 4-4 4"/>
          <path d="m16 4-4 4-4-4"/>
          <path d="m8 20 4-4 4 4"/>
        </svg>
        <h2>Refrigeration</h2>
        <p>Ice Makers, Walk-In Coolers &amp; Boxes, Reach-In Coolers, Under-Counter Refrigerators</p>
        <a href="/pages/contact" class="link-gold" style="display:inline-block;margin-top:1rem;font-family:'Oswald',sans-serif;font-size:0.875rem;font-weight:600;text-transform:uppercase;letter-spacing:0.05em;color:var(--gold);">Request Quote &rarr;</a>
      </div>

      <!-- Compressed Gas -->
      <div class="catalog-cat-card">
        <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
        </svg>
        <h2>Compressed Gas</h2>
        <p>CO2, G-Mix, Beer Gas, Nitrogen, Helium — all your commercial gas needs</p>
        <a href="/pages/contact" class="link-gold" style="display:inline-block;margin-top:1rem;font-family:'Oswald',sans-serif;font-size:0.875rem;font-weight:600;text-transform:uppercase;letter-spacing:0.05em;color:var(--gold);">Request Quote &rarr;</a>
      </div>

      <!-- Syrups & Beverages -->
      <div class="catalog-cat-card">
        <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M17 8h1a4 4 0 1 1 0 8h-1"/>
          <path d="M3 8h14v9a4 4 0 0 1-4 4H7a4 4 0 0 1-4-4V8z"/>
          <line x1="6" y1="2" x2="6" y2="4"/><line x1="10" y1="2" x2="10" y2="4"/><line x1="14" y1="2" x2="14" y2="4"/>
        </svg>
        <h2>Syrups &amp; Beverages</h2>
        <p>House Brand Cola, Diet Cola, Lemon Up, Cherry Cola, Root Beer, Ginger Ale, Coca Cola Brand Products</p>
        <a href="/pages/contact" class="link-gold" style="display:inline-block;margin-top:1rem;font-family:'Oswald',sans-serif;font-size:0.875rem;font-weight:600;text-transform:uppercase;letter-spacing:0.05em;color:var(--gold);">Request Quote &rarr;</a>
      </div>

    </div>

    <div style="text-align:center;margin-top:3rem;">
      <a href="/pages/contact" class="btn btn-gold">Request a Quote</a>
    </div>
  </div>
</section>


<!-- Page Hero -->
<section class="page-hero"
  style="background-image: url({{ 'services-hero.jpg' | asset_url }});">
  <div class="page-hero-overlay"></div>
  <div class="container page-hero-content">
    <h1>Product Catalog</h1>
  </div>
</section>

<!-- Coming Soon -->
<section style="background-color: var(--background); padding: 5rem 0;">
  <div class="container" style="max-width: 640px; margin: 0 auto; text-align: center;">
    <h2 class="font-heading" style="font-size: 2rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; color: var(--foreground);">
      Coming Soon
    </h2>
    <p class="font-body" style="margin-top: 1rem; color: var(--muted-fg);">
      Our online catalog is currently being built. Check back soon!
    </p>
  </div>
</section>


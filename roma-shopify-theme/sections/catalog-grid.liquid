<!-- Page Hero -->
<section class="page-hero"
  style="background-image: url({{ 'services-hero.jpg' | asset_url }});">
  <div class="page-hero-overlay"></div>
  <div class="container page-hero-content">
    <h1>Product Catalog</h1>
    <p>Browse our complete range of commercial beverage equipment and services.</p>
  </div>
</section>

<!-- Shopify Collection Products (live) -->
<section class="section-products-shopify">
  <div class="container">

    {%- if collection.products.size > 0 -%}
      <div class="shopify-products-grid">
        {%- for product in collection.products -%}
          <a href="{{ product.url }}" class="shopify-product-card">
            <div class="img-wrap">
              {%- if product.featured_image -%}
                <img src="{{ product.featured_image | image_url: width: 600 }}"
                     alt="{{ product.featured_image.alt | default: product.title | escape }}"
                     width="600" loading="lazy">
              {%- else -%}
                <div style="display:flex;align-items:center;justify-content:center;height:100%;
                            color:var(--muted-fg);font-family:'Oswald',sans-serif;font-size:0.875rem;
                            text-transform:uppercase;">No Image</div>
              {%- endif -%}
            </div>
            <div class="card-body">
              <h3>{{ product.title }}</h3>
              <p class="price">
                {%- if product.price_varies -%}
                  From {{ product.price_min | money }}
                {%- else -%}
                  {{ product.price | money }}
                {%- endif -%}
              </p>
              <span class="btn-view">View Details &rarr;</span>
            </div>
          </a>
        {%- endfor -%}
      </div>

      {%- if paginate.pages > 1 -%}
        <div style="text-align:center;margin-top:3rem;">
          {{ paginate | default_pagination }}
        </div>
      {%- endif -%}

    {%- else -%}
      <!-- Fallback static categories when no products are added yet -->
      <p style="text-align:center;font-family:'Source Sans 3',sans-serif;color:var(--muted-fg);margin-bottom:2rem;">
        Browse our product categories below, or <a href="/pages/contact" style="color:var(--gold);">contact us</a> to inquire about any item.
      </p>
      <div class="catalog-categories-grid">

        <div class="catalog-cat-card">
          <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none"
               stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M17 11h1a3 3 0 0 1 0 6h-1"/>
            <path d="M9 12v6"/><path d="M13 12v6"/>
            <path d="M14 7.5c-1 0-1.44.5-3 .5s-2-.5-3-.5-1.44.5-3 .5"/>
            <path d="M14 4.5c-1 0-1.44.5-3 .5s-2-.5-3-.5-1.44.5-3 .5"/>
            <path d="M3 7.5h14v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-9z"/>
          </svg>
          <h2>Beer Equipment</h2>
          <p>Draft beer systems, kegerators, glycol systems, beer towers and accessories.</p>
          <a href="/pages/contact" class="link-gold" style="display:inline-block;margin-top:1rem;font-family:'Oswald',sans-serif;font-size:0.875rem;font-weight:600;text-transform:uppercase;letter-spacing:0.05em;color:var(--gold);">Inquire &rarr;</a>
        </div>

        <div class="catalog-cat-card">
          <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none"
               stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M7 16.3c2.2 0 4-1.83 4-4.05 0-1.16-.57-2.26-1.71-3.19S7.29 6.75 7 5.3
                     c-.29 1.45-1.14 2.84-2.29 3.76S3 11.1 3 12.25c0 2.22 1.8 4.05 4 4.05z"/>
            <path d="M12.56 6.6A10.97 10.97 0 0 0 14 3.02c.5 2.5 2 4.9 4 6.5s3 3.5 3 5.5
                     a6.98 6.98 0 0 1-11.91 4.97"/>
          </svg>
          <h2>Beverages</h2>
          <p>Syrups, concentrates, and beverage products for commercial dispensing.</p>
          <a href="/pages/contact" class="link-gold" style="display:inline-block;margin-top:1rem;font-family:'Oswald',sans-serif;font-size:0.875rem;font-weight:600;text-transform:uppercase;letter-spacing:0.05em;color:var(--gold);">Inquire &rarr;</a>
        </div>

        <div class="catalog-cat-card">
          <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none"
               stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M15 11h.01"/><path d="M11 15h.01"/><path d="M16 16h.01"/>
            <path d="m2 2 20 20"/>
            <path d="M5.58 5.59A7.009 7.009 0 0 0 5 8c0 2.76 2.24 5 5 5 .82 0 1.6-.21 2.27-.58"/>
            <path d="M10.51 4.14C11 4.04 11.5 4 12 4a7 7 0 0 1 6.95 6.03"/>
          </svg>
          <h2>Liquor Management</h2>
          <p>Liquor control and dispensing systems for bars and restaurants.</p>
          <a href="/pages/contact" class="link-gold" style="display:inline-block;margin-top:1rem;font-family:'Oswald',sans-serif;font-size:0.875rem;font-weight:600;text-transform:uppercase;letter-spacing:0.05em;color:var(--gold);">Inquire &rarr;</a>
        </div>

        <div class="catalog-cat-card">
          <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none"
               stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77
                     a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91
                     a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>
          </svg>
          <h2>Services</h2>
          <p>Installation, maintenance, line cleaning, and 24-hour repair services.</p>
          <a href="/pages/services" class="link-gold" style="display:inline-block;margin-top:1rem;font-family:'Oswald',sans-serif;font-size:0.875rem;font-weight:600;text-transform:uppercase;letter-spacing:0.05em;color:var(--gold);">Learn More &rarr;</a>
        </div>

        <div class="catalog-cat-card">
          <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none"
               stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M7 16.3c2.2 0 4-1.83 4-4.05 0-1.16-.57-2.26-1.71-3.19S7.29 6.75 7 5.3
                     c-.29 1.45-1.14 2.84-2.29 3.76S3 11.1 3 12.25c0 2.22 1.8 4.05 4 4.05z"/>
            <path d="M12.56 6.6A10.97 10.97 0 0 0 14 3.02c.5 2.5 2 4.9 4 6.5s3 3.5 3 5.5
                     a6.98 6.98 0 0 1-11.91 4.97"/>
          </svg>
          <h2>Soda Equipment</h2>
          <p>Soda fountains, bar guns, jet sprays, and carbonation systems.</p>
          <a href="/pages/contact" class="link-gold" style="display:inline-block;margin-top:1rem;font-family:'Oswald',sans-serif;font-size:0.875rem;font-weight:600;text-transform:uppercase;letter-spacing:0.05em;color:var(--gold);">Inquire &rarr;</a>
        </div>

        <div class="catalog-cat-card">
          <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none"
               stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M17 8h1a4 4 0 1 1 0 8h-1"/>
            <path d="M3 8h14v9a4 4 0 0 1-4 4H7a4 4 0 0 1-4-4V8z"/>
            <line x1="6" y1="2" x2="6" y2="4"/><line x1="10" y1="2" x2="10" y2="4"/><line x1="14" y1="2" x2="14" y2="4"/>
          </svg>
          <h2>Water Systems</h2>
          <p>Crysalli water filtration, bottled water alternatives, and water dispensing.</p>
          <a href="/pages/contact" class="link-gold" style="display:inline-block;margin-top:1rem;font-family:'Oswald',sans-serif;font-size:0.875rem;font-weight:600;text-transform:uppercase;letter-spacing:0.05em;color:var(--gold);">Inquire &rarr;</a>
        </div>

      </div><!-- /.catalog-categories-grid -->
    {%- endif -%}

  </div><!-- /.container -->
</section>

{% schema %}
{
  "name": "Catalog Grid",
  "settings": [],
  "presets": [
    {
      "name": "Catalog Grid",
      "category": "Products"
    }
  ]
}
{% endschema %}

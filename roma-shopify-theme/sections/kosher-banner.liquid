<section class="section-kosher"
  style="background-image: url({% if section.settings.background_image != blank %}{{ section.settings.background_image | image_url: width: 1920 }}{% else %}{{ 'services-hero.jpg' | asset_url }}{% endif %});">
  <div class="overlay"></div>
  <div class="container inner">
    <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none"
         stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
    </svg>
    <h2>We Are Proud to Sell Kosher Products</h2>
    <p>Call Today &mdash; <a href="tel:718-259-1842">718-259-1842</a></p>
    <a href="/collections/all" class="btn btn-gold" style="margin-top:1.5rem;display:inline-flex;">
      View Online Catalog
    </a>
  </div>
</section>

{% schema %}
{
  "name": "Kosher Banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image"
    }
  ],
  "presets": [
    {
      "name": "Kosher Banner",
      "category": "Image"
    }
  ]
}
{% endschema %}

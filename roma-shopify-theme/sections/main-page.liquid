<!-- Generic page template — renders the page title and Shopify rich text content -->
<section class="page-hero">
  <div class="container page-hero-content">
    <h1>{{ page.title }}</h1>
  </div>
</section>

<section style="background-color:var(--background);padding:5rem 0;">
  <div class="container">
    <div style="max-width:56rem;margin:0 auto;font-family:'Source Sans 3',sans-serif;
                font-size:1.0625rem;line-height:1.8;color:var(--muted-fg);">
      {{ page.content }}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Page",
  "settings": []
}
{% endschema %}

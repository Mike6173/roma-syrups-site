<!-- Page Hero -->
<section class="page-hero"
  style="background-image: url({{ 'services-hero.jpg' | asset_url }});">
  <div class="page-hero-overlay"></div>
  <div class="container page-hero-content">
    <h1>Who We Service</h1>
    <p>Reputation Takes Us a Long Way</p>
  </div>
</section>

<!-- Content -->
<section class="section-who-we-service">
  <div class="container">
    <div class="who-we-service-layout">

      <!-- Business list -->
      <div>
        <h2 style="font-family:'Oswald',sans-serif;font-size:1.5rem;font-weight:700;
                   text-transform:uppercase;letter-spacing:0.05em;color:var(--foreground);">
          Some of the businesses we proudly serve:
        </h2>
        <div class="business-list-grid">
          <div class="business-item"><span class="business-dot"></span>Casinos</div>
          <div class="business-item"><span class="business-dot"></span>Restaurants</div>
          <div class="business-item"><span class="business-dot"></span>Bars and Lounges</div>
          <div class="business-item"><span class="business-dot"></span>Cafeterias</div>
          <div class="business-item"><span class="business-dot"></span>Hotels</div>
          <div class="business-item"><span class="business-dot"></span>Hospitals</div>
          <div class="business-item"><span class="business-dot"></span>Schools</div>
          <div class="business-item"><span class="business-dot"></span>Fast Food Franchises</div>
          <div class="business-item"><span class="business-dot"></span>Catering Halls</div>
          <div class="business-item"><span class="business-dot"></span>Coffee Shops</div>
          <div class="business-item"><span class="business-dot"></span>Nursing Homes</div>
          <div class="business-item"><span class="business-dot"></span>Ice Cream Parlors</div>
          <div class="business-item"><span class="business-dot"></span>Stationery Stores</div>
          <div class="business-item"><span class="business-dot"></span>Discount Stores</div>
          <div class="business-item"><span class="business-dot"></span>Sandwich Shops</div>
          <div class="business-item"><span class="business-dot"></span>Stadiums</div>
          <div class="business-item"><span class="business-dot"></span>Movie Theaters</div>
          <div class="business-item"><span class="business-dot"></span>Airport Terminal Shops</div>
        </div>
      </div>

      <!-- Sidebar -->
      <div>
        <div class="sidebar-card bordered">
          <h3>Did You Know?</h3>
          <p>Roma Syrups has been serving the NYC &amp; NJ hospitality industry since 1979. Browse our full catalog to see how we can help your business.</p>
          <a href="/collections/all" class="btn-gold-sm">View Catalog</a>
        </div>
        <div class="sidebar-card dark" style="margin-top:1.5rem;">
          <h3>Ready to Get Started?</h3>
          <p>Contact us for a free consultation and quote.</p>
          <a href="/pages/contact" class="btn-gold-sm">Contact Us</a>
        </div>
      </div>

    </div><!-- /.who-we-service-layout -->
  </div><!-- /.container -->
</section>


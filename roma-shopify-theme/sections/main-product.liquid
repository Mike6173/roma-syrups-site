<section class="section-product">
  <div class="container">
    <div class="product-layout">

      <!-- Product Images -->
      <div class="product-images">
        <div class="main-img">
          {%- if product.featured_image -%}
            <img src="{{ product.featured_image | image_url: width: 800 }}"
                 alt="{{ product.featured_image.alt | default: product.title | escape }}"
                 id="main-product-image" width="800" loading="eager">
          {%- else -%}
            <div style="display:flex;align-items:center;justify-content:center;height:100%;
                        min-height:300px;color:var(--muted-fg);font-family:'Oswald',sans-serif;
                        font-size:1rem;text-transform:uppercase;">No Image Available</div>
          {%- endif -%}
        </div>

        {%- if product.images.size > 1 -%}
          <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:0.5rem;margin-top:0.75rem;">
            {%- for image in product.images -%}
              <div style="border-radius:var(--radius);overflow:hidden;border:2px solid transparent;
                          cursor:pointer;aspect-ratio:1;"
                   onclick="document.getElementById('main-product-image').src='{{ image | image_url: width: 800 }}'">
                <img src="{{ image | image_url: width: 200 }}"
                     alt="{{ image.alt | default: product.title | escape }}"
                     style="width:100%;height:100%;object-fit:cover;" loading="lazy">
              </div>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>

      <!-- Product Info -->
      <div class="product-info">
        <h1>{{ product.title }}</h1>

        <p class="price">
          {%- if product.price_varies -%}
            From {{ product.price_min | money }}
          {%- elsif product.compare_at_price > product.price -%}
            <span style="text-decoration:line-through;color:var(--muted-fg);font-size:1rem;">
              {{ product.compare_at_price | money }}
            </span>
            {{ product.price | money }}
          {%- else -%}
            {{ product.price | money }}
          {%- endif -%}
        </p>

        {%- if product.description != blank -%}
          <div class="description">{{ product.description }}</div>
        {%- endif -%}

        {%- form 'product', product, class: 'product-form' -%}
          <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">

          {%- unless product.has_only_default_variant -%}
            {%- for option in product.options_with_values -%}
              <div style="margin-bottom:1rem;">
                <label style="display:block;font-family:'Oswald',sans-serif;font-size:0.875rem;
                              font-weight:600;text-transform:uppercase;letter-spacing:0.05em;
                              color:var(--foreground);margin-bottom:0.375rem;">
                  {{ option.name }}
                </label>
                <select name="options[{{ option.name | escape }}]">
                  {%- for value in option.values -%}
                    <option value="{{ value | escape }}"
                      {%- if option.selected_value == value %} selected{%- endif -%}>
                      {{ value }}
                    </option>
                  {%- endfor -%}
                </select>
              </div>
            {%- endfor -%}
          {%- endunless -%}

          <div style="margin-bottom:1rem;">
            <label style="display:block;font-family:'Oswald',sans-serif;font-size:0.875rem;
                          font-weight:600;text-transform:uppercase;letter-spacing:0.05em;
                          color:var(--foreground);margin-bottom:0.375rem;">Quantity</label>
            <input type="number" name="quantity" value="1" min="1"
                   style="width:6rem;" aria-label="Quantity">
          </div>

          <button type="submit" name="add" class="btn-add-to-cart"
            {%- unless product.selected_or_first_available_variant.available %} disabled{%- endunless -%}>
            {%- if product.selected_or_first_available_variant.available -%}
              Add to Cart
            {%- else -%}
              Sold Out
            {%- endif -%}
          </button>
        {%- endform -%}

        <!-- Contact CTA for quote -->
        <p style="margin-top:1.25rem;font-family:'Source Sans 3',sans-serif;font-size:0.875rem;
                  color:var(--muted-fg);">
          Need a custom quote?
          <a href="/pages/contact" style="color:var(--gold);font-weight:600;">Contact us</a>
          or call <a href="tel:718-259-1842" style="color:var(--gold);font-weight:600;">718-259-1842</a>
        </p>
      </div>

    </div><!-- /.product-layout -->
  </div><!-- /.container -->
</section>

{% schema %}
{
  "name": "Product",
  "settings": []
}
{% endschema %}

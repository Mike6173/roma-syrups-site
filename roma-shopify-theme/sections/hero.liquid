<section class="hero"
  style="background-image: url({% if section.settings.hero_image != blank %}{{ section.settings.hero_image | image_url: width: 1920 }}{% else %}{{ 'hero-bar.jpg' | asset_url }}{% endif %});">
  <div class="hero-overlay-layer"></div>
  <div class="hero-content container">
    <div class="inner">
      <h1>{{ section.settings.heading | default: 'Welcome to Roma Syrups and Beverage Systems' }}</h1>
      <p>{{ section.settings.subheading | default: 'We specialize in Soda Systems, Draft Beer Systems, Glycol Systems, Water Systems, Compressed Gas, Coffee on Tap, Wine on Tap, Ice Makers, Refrigeration, Walk-In Boxes and more.' }}</p>
      <div class="hero-actions">
        <a href="{{ section.settings.cta_primary_url | default: '/pages/contact' }}" class="btn btn-gold">
          {{ section.settings.cta_primary_label | default: 'Get a Free Consultation' }}
        </a>
        <a href="tel:718-259-1842" class="btn btn-outline-gold">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none"
               stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12
                     19.79 19.79 0 0 1 1.61 3.44 2 2 0 0 1 3.59 1h3a2 2 0 0 1 2 1.72
                     12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 8.91
                     a16 16 0 0 0 6.29 6.29l.75-.75a2 2 0 0 1 2.11-.45
                     12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
          </svg>
          Call 718-259-1842
        </a>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero background image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Welcome to Roma Syrups and Beverage Systems"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "We specialize in Soda Systems, Draft Beer Systems, Glycol Systems, Water Systems, Compressed Gas, Coffee on Tap, Wine on Tap, Ice Makers, Refrigeration, Walk-In Boxes and more."
    },
    {
      "type": "text",
      "id": "cta_primary_label",
      "label": "Primary CTA label",
      "default": "Get a Free Consultation"
    },
    {
      "type": "url",
      "id": "cta_primary_url",
      "label": "Primary CTA URL"
    }
  ],
  "presets": [
    {
      "name": "Hero",
      "category": "Image"
    }
  ]
}
{% endschema %}
